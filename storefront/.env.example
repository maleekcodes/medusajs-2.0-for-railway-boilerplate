# Copy to `.env.local`. Never commit real tokens.

# --- Medusa (required for storefront) ---
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000
NEXT_PUBLIC_BASE_URL=http://localhost:8000
NEXT_PUBLIC_DEFAULT_REGION=us
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=

# --- Checkout: Stripe.js (Medusa payment-stripe) ---
# Publishable key from the same Stripe account as the backend STRIPE_API_KEY.
# Required for card entry on /checkout when Stripe is the active payment provider.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Alias (either this or NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY):
# NEXT_PUBLIC_STRIPE_KEY=

# --- Sanity (CMS; server-side GROQ via @sanity/client) ---
# Use the SAME project + dataset as Sanity Studio (`sanity/sanity.config.ts`):
#   SANITY_STUDIO_PROJECT_ID (or default bff91fb2) === SANITY_PROJECT_ID here
#   SANITY_STUDIO_DATASET (usually production) === SANITY_DATASET here
# Project ID from https://www.sanity.io/manage → Project → API
SANITY_PROJECT_ID=
SANITY_DATASET=production
SANITY_API_VERSION=2024-01-01
# Optional: Viewer token for draft/preview; leave unset to use the public API CDN for published content only.
SANITY_TOKEN=

# --- OOO (Highest Expression): optional embed URL override (default: HubSpot) ---
# NEXT_PUBLIC_PRIVATE_EXPRESSIONS_TYPEFORM_URL=https://custom-form-url-if-needed

# --- Digital PDP: virtual try-on (server-only) ---
VIRTUAL_TRYON_API_KEY=
# Optional: override API origin (defaults work if unset)
# VIRTUAL_TRYON_PROVIDER_BASE_URL=

# --- Digital PDP: Stripe Checkout (server-only) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Digital PDP: signed try-on preview (server-only; never commit real value) ---
# HMAC-signs `/api/try-on/preview` URLs. If unset, STRIPE_WEBHOOK_SECRET or MINIO_SECRET_KEY is used (same deploy).
DIGITAL_PREVIEW_HMAC_SECRET=

# --- Digital PDP: MinIO / S3-compatible storage for persisted try-on files ---
# Same bucket as Medusa is fine; keys are prefixed with `digital-tryon/`.
MINIO_ENDPOINT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=medusa-media
# Optional: full URL if MINIO_ENDPOINT is host-only (default https)
MINIO_USE_SSL=true
MINIO_SERVER_URL=
